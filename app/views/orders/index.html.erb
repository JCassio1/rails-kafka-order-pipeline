<h1>Orders</h1>

<% if notice %>
  <p style="color: green"><%= notice %></p>
<% end %>

<%= link_to "New Order", new_order_path %>

<div class="w-full max-w-2xl">
  <h2 class="text-2xl font-bold mb-4">Latest Orders</h2>

  <% if @orders.any? %>
    <div class="grid gap-4">
      <% @orders.each do |order| %>
        <%= render RubyUI::Card.new do %>
          <%= render RubyUI::CardHeader.new do %>
            <%= render RubyUI::CardTitle.new do %>
              <%= order.description %>
            <% end %>
          <% end %>

          <%= render RubyUI::CardContent.new do %>
            <%= render RubyUI::CardDescription.new do %>
              Status:
              <span class="<%= order.status == 'processed' ? 'text-green-600' : 'text-yellow-600' %> font-medium">
                <%= order.status %>
              </span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">No orders yet.</p>
  <% end %>
</div>
