<article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <p class="text-base text-gray-900"><%= order.description %></p>
    <span class="rounded-full px-3 py-1 text-sm font-medium <%= order.status == 'processed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
      <%= order.status %>
    </span>
  </div>
</article>
